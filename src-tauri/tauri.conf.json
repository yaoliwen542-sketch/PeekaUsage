{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PeekaUsage",
  "version": "0.1.10",
  "identifier": "com.peekausage.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PeekaUsage",
        "width": 280,
        "height": 400,
        "minWidth": 220,
        "minHeight": 200,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5QkVBMDQxNUJGQkREMkQKUldRdDNmdGJRYUMrYVpiNjF6U0F2MU1JRmV5YkZ1bWc3VzBhbmhlMUtEQ0YxcTFhMThzaW93V1UK",
      "endpoints": [
        "https://github.com/StarChen4/PeekaUsage/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
