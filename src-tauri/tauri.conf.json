{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PeekaUsage",
  "version": "0.2.0",
  "identifier": "com.peekausage.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PeekaUsage",
        "width": 400,
        "height": 500,
        "minWidth": 320,
        "minHeight": 300,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": true,
        "visible": true
      },
      {
        "label": "island",
        "title": "PeekaUsage Island",
        "width": 200,
        "height": 40,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "center": false,
        "x": 560,
        "y": 40
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5QkVBMDQxNUJGQkREMkQKUldRdDNmdGJRYUMrYVpiNjF6U0F2MU1JRmV5YkZ1bWc3VzBhbmhlMUtEQ0YxcTFhMThzaW93V1UK",
      "endpoints": [
        "https://github.com/yaoliwen542-sketch/PeekaUsage/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
